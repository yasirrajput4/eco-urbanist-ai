# ─── Node / Frontend ────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── Python / Backend ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
env/
ENV/


# ─── TensorFlow / ML ────────────────────────────────────────
# Ignore all .h5 model files EXCEPT the ones tracked in backend/models/
*.h5


*.pb
*.ckpt
*.ckpt.index
*.ckpt.data-*
*.ckpt.meta

# TF SavedModel directories
saved_model/
checkpoints/


# ─── Data ───────────────────────────────────────────────────
data/train/*
data/test/*
data/output/*
# Keep folder structure in git
!data/train/.gitkeep
!data/test/.gitkeep
!data/output/.gitkeep

# Any leftover archive dumps
archive*/


# ─── Logs ───────────────────────────────────────────────────
logs/
*.log


# ─── Environment & Secrets ──────────────────────────────────
.env
.env.local
.env.*.local
.env.example

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.sw?


# ─── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

outputs/