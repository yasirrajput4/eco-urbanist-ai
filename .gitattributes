# ─── Line endings ───────────────────────────────────────────
# Normalize line endings to LF on commit (cross-platform safety)
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf


# ─── Git LFS — Large / Binary model files ───────────────────
backend/models/*.h5  filter=lfs diff=lfs merge=lfs -text
*.pb                 filter=lfs diff=lfs merge=lfs -text
*.ckpt               filter=lfs diff=lfs merge=lfs -text
*.ckpt.index         filter=lfs diff=lfs merge=lfs -text
*.ckpt.data-*        filter=lfs diff=lfs merge=lfs -text


# ─── Binary assets (no diffs, no merges) ────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text

*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary

*.zip  binary
*.tar  binary
*.gz   binary


# ─── Language stats (GitHub Linguist) ───────────────────────
# Exclude generated / vendored files from language detection
dist/**         linguist-generated=true
node_modules/** linguist-vendored=true
venv/**         linguist-vendored=true
.venv/**        linguist-vendored=true